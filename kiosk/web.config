<?xml version="1.0" encoding="UTF-8"?>
<!--
    IIS static-hosting config for the PingCanvas kiosk site.
    Drop the kiosk app files, board.xcanvas, and the poller's status output into
    this site's folder (one origin, so the fetch is same-origin). IIS serves
    everything as static files - no server-side code.

    If you add a Content-Security-Policy here (or reuse CrossCanvas's stricter
    web.config), script-src MUST allow the kiosk's inline embed flag:
      'sha256-M3xh1E6BobQqrgZB9DFnlbp/+XByW49Qhf+08vqZtL8='
    (the hash of "window.CROSSCANVAS_EMBED = true;" injected into kiosk.html).
    Blocking it silently boots the wall in editor mode - autosave prompts can
    then freeze an unattended screen.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <!-- Serve .xcanvas as JSON so the kiosk can fetch and parse the board.
           (.netdraw = the pre-rename extension, honored forever.) -->
      <remove fileExtension=".xcanvas" />
      <mimeMap fileExtension=".xcanvas" mimeType="application/json" />
      <remove fileExtension=".netdraw" />
      <mimeMap fileExtension=".netdraw" mimeType="application/json" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- Don't let the browser MIME-sniff the JSON/JS the kiosk serves.
             <remove> first so this can't 500 with "duplicate collection entry"
             if a parent/server-level config already sends the same header. -->
        <remove name="X-Content-Type-Options" />
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

    <!--
      The kiosk already cache-busts status fetches with ?t=<timestamp>, so stale
      caching isn't a real risk. If you want belt-and-suspenders no-cache on the
      JSON feed, install the URL Rewrite + outbound rules module and uncomment,
      or set it per-file with a <location> block like the example below.
    -->
    <!--
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
      </customHeaders>
    </httpProtocol>
    -->
  </system.webServer>
</configuration>
