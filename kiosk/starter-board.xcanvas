      ],
      "spans": [
        [
          {
            "text": "This message indicates you haven't loaded any .xcanvas files into the PingCanvas web folder.",
            "bold": true,
            "italic": false
          }
        ],
        [
          {
            "text": "",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "1. Open the editor (index.html) and draw your network - or File → Load Sample.",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "2. Add an IP address to each device you want monitored. (Device Details)",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "3. Save, and place the file as board.xcanvas in the data folder",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "Windows",
            "bold": true,
            "italic": false
          },
          {
            "text": ": C:\\PingCanvas\\web",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "Docker",
            "bold": true,
            "italic": false
          },
          {
            "text": ": ./data",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "IIS",
            "bold": true,
            "italic": false
          },
          {
            "text": ": Site Root (e.g. C:\\inetpub\\wwwroot )",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "4. Make sure the poller is running:",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "Docker",
            "bold": true,
            "italic": false
          },
          {
            "text": ": docker compose up ",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "Windows",
            "bold": true,
            "italic": false
          },
          {
            "text": ": Check scheduled task",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "The poller pings your devices and writes the results back to a status file.",
            "bold": false,
            "italic": false
          }
        ],
        [
          {
            "text": "Once the poller has started and a .xcanvas in place, refresh this page.",
            "bold": false,
            "italic": false
          }
        ]
      ]
    }
